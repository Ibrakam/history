ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
SESSION_SECRET=change-me

# Локальная OpenAI-compatible модель, например Ollama:
# ollama pull qwen2.5:7b-instruct
OPENAI_API_KEY=
OPENAI_MODEL=qwen2.5:7b-instruct
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
AI_REQUEST_TIMEOUT=60

# Для сервера или облачного OpenAI-compatible API укажите ключ и внешний URL:
# OPENAI_API_KEY=...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
USE_DEMO_AI=false
ENABLE_EXTERNAL_MEDIA_SEARCH=true
ENABLE_SOURCE_MATERIALS=true
SOURCE_FIRST_GENERATION=false
SOURCE_MATERIAL_LIMIT=10
SOURCE_MATERIAL_MIN_SCORE=4.0
FRONTEND_ORIGIN=http://localhost:5173
DATABASE_URL=sqlite:///./history.db
WIKIMEDIA_API_URL=https://commons.wikimedia.org/w/api.php
